<!--
 Author: Ray Barham
 Description: This velocity template is a resource of the com.atlassian.jira.issue.customfields.impl.WatcherFieldType class.  It will
 parse templates/plugins/fields/edit/edit-multiuser.vm if the user has "Manage Watcher List" permissions and displays a message if
 the watcher list if not.
-->

#if($hasPermission)
    #parse("templates/plugins/fields/edit/edit-multiuser.vm")
#else
    #controlHeader ($action $customField.id $customField.name $fieldLayoutItem.required $displayParameters.noHeader)
    <strong>$i18n.getText("watcherfield.nopermission.body")</strong>
    #if ($value)
        <br/>
	    #foreach ($singleValue in $value)
		    <span class="tinylink">$userformat.formatUser($singleValue, 'profileLink', "multiuser_cf")</span>#comma ($value)
	    #end
    #end
    #controlFooter ($action $fieldLayoutItem.fieldDescription $displayParameters.noHeader)
#end