<atlassian-plugin key="${project.groupId}.${project.artifactId}" name="${project.name}" pluginsVersion="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
    </plugin-info>
    <resource
		type="i18n"
		name="i18n"
		location="WatcherFieldType"	/>

	<customfield-type
			key="watcherfieldtype"
			i18n-name-key="watcherfield.type.name"
			class="com.burningcode.jira.issue.customfields.impl.WatcherFieldType">
		<description key="watcherfield.type.desc" />
		<resource
			type="velocity"
			name="column-view"
			location="templates/plugins/fields/view/column-view-multiuser.vm"/>
		<resource
			type="velocity"
			name="edit"
			location="templates/plugins/fields/edit/edit-watcherfield.vm"/>
	</customfield-type>
 
	<customfield-searcher
			key="watcherfieldsearcher"
		    i18n-name-key="watcherfield.searcher.name"
		    class="com.burningcode.jira.issue.customfields.searchers.WatcherSearcher">
	    <description key="watcherfield.searcher.desc" />
	    <resource
	    	type="velocity"
	    	name="search"
	    	location="templates/plugins/fields/edit-searcher/search-userpicker.vm"
	    	/>
	    <resource
	    	type="velocity"
	    	name="view"
	    	location="templates/plugins/fields/view-searcher/view-searcher-basictext.vm"
	    	/>
	    <valid-customfield-type
	    	package="${project.groupId}.${project.artifactId}"
	    	key="watcherfieldtype"
	    	/>
	</customfield-searcher>

	<web-section key="watchers-section" location="admin_plugins_menu">
		<label>Watchers Custom Field</label>
	</web-section>

	<web-item key="watcherfieldSettingsLink"
			i18n-name-key="watcherfield.settings.link.name"
			section="admin_plugins_menu/watchers-sections"
			weight="90">
        <description key="watcherfield.settings.link.desc" />
        <label key="watcherfield.settings.link.label" />
        <link linkId="watcher_field_settings_link">/secure/project/WatcherFieldSettings.jspa</link>
    </web-item>
    
	<webwork1 key="watcherfieldSettings"
			class="java.lang.Object"
			i18n-name-key="watcherfield.settings.name" >
		<description key="watcherfield.settings.desc" />
        <condition class="com.atlassian.jira.plugin.webfragment.conditions.JiraGlobalPermissionCondition">
		    <param name="permission">admin</param>
		</condition>
        <actions>
            <action name="com.burningcode.jira.plugin.WatcherFieldSettings" alias="WatcherFieldSettings" >
                <view name="success">/templates/settings/watcherfield.vm</view>
               	<view name="permissionviolation">/secure/views/securitybreach.jsp</view>
            </action>
            <action name="com.burningcode.jira.plugin.WatcherFieldSettings" alias="EditWatcherFieldSettings" >
                <view name="input">/templates/settings/edit-watcherfield.vm</view>
               	<view name="permissionviolation">/secure/views/securitybreach.jsp</view>
            </action>
        </actions>
    </webwork1>

</atlassian-plugin>