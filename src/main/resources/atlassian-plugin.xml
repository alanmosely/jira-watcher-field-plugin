<atlassian-plugin key="${project.groupId}.${project.artifactId}" name="${project.name}" plugins-version="2">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
    </plugin-info>
    <resource
		type="i18n"
		name="i18n"
		location="WatcherFieldType"
		/>
    <webwork1
    		key="managewatchersreindex"
    		i18n-name-key="watcherfield.manager.name"
    	>
    	<description key="watcherfield.manager.desc" />
		<actions>
			<!-- Copied and modified from actions.xml -->
		    <action name="com.burningcode.jira.web.action.issue.ManageWatchersReindex" alias="ManageWatchers">
		        <view name="success">/secure/views/issue/managewatchers.jsp</view>
		        <view name="input">/secure/views/issue/managewatchers.jsp</view>
		        <view name="error">/secure/views/issue/managewatchers.jsp</view>
		        <view name="watchingnotenabled">/secure/views/issue/managewatchers.jsp</view>
		        <view name="securitybreach">/secure/views/securitybreach.jsp</view>
		    </action>
	    </actions>
    </webwork1>
	<customfield-type
			key="watcherfieldtype"
			i18n-name-key="watcherfield.type.name"
			class="com.burningcode.jira.issue.customfields.impl.WatcherFieldType">
		<description key="watcherfield.type.desc" />
		<resource
			type="velocity"
			name="view"
			location="templates/plugins/fields/view/view-multiuser.vm"/>
		<resource
			type="velocity"
			name="edit"
			location="templates/plugins/fields/edit/edit-watcherfield.vm"/>
	</customfield-type>
	<!-- 
	<customfield-searcher
			key="watcherfieldsearcher"
		    i18n-name-key="watcherfield.searcher.name"
		    class="com.atlassian.jira.issue.customfields.searchers.UserPickerSearcher">
	    <description key="watcherfield.searcher.desc" />
	    <resource
	    	type="velocity"
	    	name="search"
	    	location="templates/plugins/fields/edit-searcher/search-userpicker.vm"
	    	/>
	    <resource
	    	type="velocity"
	    	name="view"
	    	location="templates/plugins/fields/view-searcher/view-searcher-basictext.vm"
	    	/>
	    <valid-customfield-type
	    	package="${project.groupId}.${project.artifactId}"
	    	key="watcherfieldtype"
	    	/>
	</customfield-searcher>
	 -->
	<web-resource 
			key="watcherfieldjs"
			i18n-name-key="watcherfield.js.name"
		>
		<description key="watcherfield.js.desc" />
		<resource
			name="watcherfield.js"
			type="download"
			location="js/watcherfield.js"
			/>
	</web-resource>
	<rest key="watcherfieldRest" path="/watcherfield" version="1.0">
		<description key="watcherfield.rest.desc" />
	</rest>
</atlassian-plugin>