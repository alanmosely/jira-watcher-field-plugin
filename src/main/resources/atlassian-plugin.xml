<atlassian-plugin key="${project.groupId}.${project.artifactId}" name="${project.name}">
    <plugin-info>
        <description>${project.description}</description>
        <version>${project.version}</version>
        <!-- TODO: Add vendor details -->
        <!--
        <vendor name="Example Company" url="http://www.example.com"/>
        -->
    </plugin-info>
	<customfield-type
			key="watcherfieldtype"
			i18n-name-key="watcherfield.type.name"
			class="com.atlassian.jira.issue.customfields.impl.WatcherFieldType">
		<description key="watcherfield.type.desc" />
		<resource
			type="i18n"
			name="i18n"
			location="com.atlassian.jira.issue.customfields.impl.WatcherFieldType"
			/>
		<resource
			type="velocity"
			name="view"
			location="templates/plugins/fields/view/view-multiuser.vm"/>
		<resource
			type="velocity"
			name="edit"
			location="templates/plugins/fields/edit/edit-watcherfield.vm"/>
	</customfield-type>
	<customfield-searcher
			key="watcherfieldsearcher"
		    i18n-name-key="watcherfield.searcher.name"
		    class="com.atlassian.jira.issue.customfields.searchers.WatcherSearcher">
	    <description key="watcherfield.searcher.desc" />
    	<resource
			type="i18n"
			name="i18n"
			location="com.atlassian.jira.issue.customfields.impl.WatcherFieldType"
			/>
	    <resource
	    	type="velocity"
	    	name="search"
	    	location="templates/plugins/fields/edit-searcher/search-userpicker.vm"
	    	/>
	    <resource
	    	type="velocity"
	    	name="view"
	    	location="templates/plugins/fields/view-searcher/view-searcher-basictext.vm"
	    	/>
	    <valid-customfield-type
	    	package="${project.groupId}.${project.artifactId}"
	    	key="watcherfieldtype"
	    	/>
	</customfield-searcher>
</atlassian-plugin>
